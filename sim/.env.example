# SQL Server RCA Assistant environment example
# Copy this file to .env and fill in your values:
#   cp sim/.env.example sim/.env
#
# IMPORTANT: Never commit .env to version control.

# =============================================================================
# Required SQL Server target
# =============================================================================

SQLSERVER_HOST=your-sqlserver-host
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourSecurePassword123!
SQLSERVER_DATABASE=master

# Backwards-compatible aliases still accepted by some internal helpers.
# Prefer SQLSERVER_PASSWORD above for new setups.
# SA_PASSWORD=YourSecurePassword123!
# SIM_SA_PASSWORD=YourSecurePassword123!

# =============================================================================
# Optional monitoring stack
# =============================================================================

# Enable ClickHouse-backed recent-vs-baseline analysis
# SIM_ENABLE_MONITORING=1

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=rca_metrics
CLICKHOUSE_USER=rca
CLICKHOUSE_PASSWORD=rca_password

# You choose this value yourself. It becomes the Grafana admin password
# for http://localhost:3001 when you run docker compose directly.
# `python -m sim webapp start` will auto-set and print it instead.
GRAFANA_PASSWORD=ChooseYourOwnGrafanaPassword123!

# Set to true to render dashboards without interactive login inside iframes.
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ANONYMOUS_ORG_ROLE=Viewer

# =============================================================================
# Optional AI configuration
# =============================================================================

# ANTHROPIC_API_KEY=sk-ant-...
# RCA_LLM_PROVIDER=anthropic
# RCA_MODEL=claude-opus-4-1
# RCA_DEBUG=false

# =============================================================================
# Optional local sidecar compatibility settings
# =============================================================================

# These are only for optional local SQL Server container workflows.
# SIM_HOST_PORT=14333
# SIM_MEMORY_LIMIT=4g
# SIM_CPU_LIMIT=2.0
# SIM_CONTAINER_NAME=sim-sqlserver
# SIM_SQL_IMAGE=mcr.microsoft.com/mssql/server:2022-latest

# =============================================================================
# Optional web app session storage
# =============================================================================

# SIM_SESSION_BACKEND=sqlite
# SIM_SQLITE_PATH=~/.sim/sessions.db
# SIM_SESSIONS_DIR=~/.sim/sessions
# SIM_SESSION_TTL_HOURS=0
# SIM_SESSION_MIGRATION_DELETE_SOURCE=0

# =============================================================================
# Optional logging
# =============================================================================

# SIM_LOG_LEVEL=INFO
# SIM_LOG_FORMAT=text

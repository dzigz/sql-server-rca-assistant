          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT\n  concat('Q', toString(row_number() OVER (ORDER BY max_cpu DESC))) as query_label,\n  max_cpu as cpu_time_us\nFROM (\n  SELECT query_hash, max(total_worker_time_us) as max_cpu\n  FROM rca_metrics.query_stats\n  WHERE collected_at >= $__fromTime AND collected_at <= $__toTime\n    AND sql_text LIKE '%Incidents.Sim%'\n  GROUP BY query_hash\n  ORDER BY max_cpu DESC\n  LIMIT 10\n)",
          "refId": "A"
        }
      ],

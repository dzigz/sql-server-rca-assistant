          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT\n  query_hash,\n  any(substring(sql_text, 1, 100)) as query_preview,\n  max(execution_count) as executions,\n  max(total_worker_time_us) as cpu_time_us,\n  max(total_logical_reads) as logical_reads,\n  max(total_elapsed_time_us) as elapsed_time_us\nFROM rca_metrics.query_stats\nWHERE collected_at >= $__fromTime\n  AND collected_at <= $__toTime\n  AND sql_text LIKE '%Incidents.Sim%'\nGROUP BY query_hash\nORDER BY cpu_time_us DESC\nLIMIT 20",
          "refId": "A"
        }
      ],

      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-rca"
          },
          "editorType": "sql",
          "format": 0,
          "queryType": "timeseries",
          "rawSql": "SELECT\n  toStartOfMinute(collected_at) as time,\n  wait_type,\n  sum(wait_time_ms) as total_wait_ms\nFROM rca_metrics.wait_stats\nWHERE collected_at >= $__fromTime\n  AND collected_at <= $__toTime\n  AND wait_type NOT LIKE 'XE_%'\n  AND wait_type NOT LIKE 'BROKER_%'\n  AND wait_type NOT LIKE 'SLEEP_%'\n  AND wait_type NOT LIKE 'QDS_%'\n  AND wait_type NOT LIKE 'HADR_%'\nGROUP BY time, wait_type\nHAVING total_wait_ms > 0\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Wait Time Trend by Type",
      "type": "timeseries"
    },

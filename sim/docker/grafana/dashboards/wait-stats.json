      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-rca"
          },
          "editorType": "sql",
          "format": 1,
          "queryType": "table",
          "rawSql": "SELECT\n  CASE\n    WHEN wait_type LIKE 'LCK_%' THEN 'Lock'\n    WHEN wait_type LIKE 'PAGEIOLATCH_%' OR wait_type LIKE 'WRITELOG' THEN 'I/O'\n    WHEN wait_type IN ('CXPACKET', 'CXCONSUMER', 'CXSYNC_CONSUMER', 'CXSYNC_PORT') THEN 'Parallelism'\n    WHEN wait_type LIKE 'RESOURCE_SEMAPHORE%' OR wait_type LIKE 'CMEMTHREAD' THEN 'Memory'\n    WHEN wait_type LIKE 'SOS_SCHEDULER_YIELD' THEN 'CPU'\n    WHEN wait_type LIKE 'ASYNC_NETWORK_IO' THEN 'Network'\n    WHEN wait_type LIKE 'LATCH_%' THEN 'Latch'\n    ELSE 'Other'\n  END as category,\n  sum(wait_time_ms) as total_wait_ms\nFROM rca_metrics.wait_stats\nWHERE collected_at >= $__fromTime\n  AND collected_at <= $__toTime\n  AND wait_type NOT LIKE 'XE_%'\n  AND wait_type NOT LIKE 'BROKER_%'\n  AND wait_type NOT LIKE 'SLEEP_%'\n  AND wait_type NOT LIKE 'QDS_%'\nGROUP BY category\nORDER BY total_wait_ms DESC",
          "refId": "A"
        }
      ],
      "title": "Wait Time by Category",
      "type": "barchart"

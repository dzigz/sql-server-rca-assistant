      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "clickhouse-rca"
          },
          "editorType": "sql",
          "format": 0,
          "queryType": "timeseries",
          "rawSql": "SELECT\n  toStartOfMinute(collected_at) as time,\n  wait_type,\n  sum(wait_time_ms) as wait_time_ms\nFROM rca_metrics.wait_stats\nWHERE collected_at >= now() - INTERVAL 1 HOUR\n  AND wait_type NOT LIKE 'XE_%'\n  AND wait_type NOT LIKE 'BROKER_%'\n  AND wait_type NOT LIKE 'SLEEP_%'\n  AND wait_type NOT LIKE 'QDS_%'\nGROUP BY time, wait_type\nORDER BY time, wait_time_ms DESC",
          "refId": "A"
        }
      ],
      "title": "Wait Time by Type (Last Hour)",
      "type": "timeseries"
    },
